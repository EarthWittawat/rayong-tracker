# Client-side (must be NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only (Vercel env vars). Never expose in the bundle.
# Used by the /api/cron/digest route to fan out the daily digest mailer.
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
MAIL_FROM="Rayong Tracker <onboarding@resend.dev>"
APP_URL=
CRON_SECRET=

# Supabase Edge Function secrets are set separately via:
#   supabase secrets set RESEND_API_KEY=... MAIL_FROM=... APP_URL=...
